# Copy to .env and adjust. All values are optional for local use.

# Turn on the login gate. If unset/empty, the app runs open (no login).
# ADMIN_PASSWORD=change-me

# Where projects, answers and uploaded documents are stored. In Docker this is
# a mounted volume so data survives restarts.
DATA_DIR=/home/data

# Set to true when serving over HTTPS so the session cookie is HTTPS-only.
COOKIE_SECURE=false

# Max total bytes per upload submit (default 200 MB).
# MAX_UPLOAD_BYTES=209715200

# --- Estimate tender workflow (all optional; safe to leave blank) ----------- #
# Without these, the workflow uses the bundled _agent_prompts folder and
# produces clearly-labelled PLACEHOLDER pricing/tender outputs.

# AWS S3 holding the workflow-step markdown files (the _agent_prompts folder).
# AWS_REGION=eu-west-2
# AGENT_PROMPTS_S3_BUCKET=my-roofing-bucket
# AGENT_PROMPTS_S3_PREFIX=_agent_prompts/
# AWS credentials come from the standard chain (env vars / instance role):
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# Override the local fallback dir if needed:
# AGENT_PROMPTS_LOCAL_DIR=/app/_agent_prompts

# AI model that generates the pricing sheet + tender document.
# AI_PROVIDER selects the integration: "bedrock" (AWS) or "http" (generic REST).
# AI_PROVIDER=bedrock
# AI_API_KEY=...
# AI_ENDPOINT=https://...            # required for the "http" provider
# AI_MODEL_ID=anthropic.claude-...   # required for the "bedrock" provider
# AI_TIMEOUT_SECONDS=300
